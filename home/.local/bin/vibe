#!/usr/bin/env sh

output_file=$(mktemp)
model_path="/usr/share/whisper.cpp-model-large-v3-turbo/ggml-large-v3-turbo.bin"
whisper-stream --model "$model_path" --threads 16 -f "$output_file" &
pid="$!"

while [ ! -s "$FILE" ]; do
  sleep 0.1
done

read -r line < "$output_file"
kill "$pid"
printf '%s' "$line" | xclip -selection clipboard -f
xdotool type "$line"
